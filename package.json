{
  "name": "rate-limiting",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Minimal Node HTTP server with Express and a health endpoint.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",

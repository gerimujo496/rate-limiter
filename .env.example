PORT=3000
BASE_URL=http://localhost:3000
NODE_ENV=development
# Trust 1 reverse-proxy hop so rate limits key on X-Forwarded-For client IP.
# Use false/0 when hitting the app directly with no load balancer.
TRUST_PROXY=1

# Docker image used by compose service distributed_api_service (CI pushes to GHCR).
# DISTRIBUTED_API_IMAGE=ghcr.io/gerimujo496/distributed_api_service:latest

# --- Redis (rate limiter uses Upstash REST; BullMQ uses TCP) ---
# Cloud Upstash:
# UPSTASH_REDIS_REST_URL=https://....upstash.io
# UPSTASH_REDIS_REST_TOKEN=...
# Local docker compose (redis-http proxy on :8079 + redis on :6379):
UPSTASH_REDIS_REST_URL=http://127.0.0.1:8079
UPSTASH_REDIS_REST_TOKEN=local_dev_token
# Local Redis for tests / BullMQ (docker-compose redis service).
TEST_REDIS_URL=redis://127.0.0.1:6379
UPSTASH_REDIS_URL=redis://127.0.0.1:6379

# --- Postgres (docker-compose db service publishes 15432) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=15432
POSTGRES_DB=url_shortener
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:15432/url_shortener

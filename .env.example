PORT=3000
BASE_URL=http://localhost:3000
NODE_ENV=development
UPSTASH_REDIS_REST_URL=example
UPSTASH_REDIS_REST_TOKEN=example
# Local Redis for tests (docker-compose redis service).
TEST_REDIS_URL=redis://127.0.0.1:6379
POSTGRES_HOST=localhost
POSTGRES_PORT=15432
POSTGRES_DB=url_shortener
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:15432/url_shortener
# Optional: BullMQ TCP Redis connection (preferred).
# If unset, BullMQ derives host from UPSTASH_REDIS_REST_URL + token.
# UPSTASH_REDIS_URL=rediss://default:password@example.upstash.io:6379
